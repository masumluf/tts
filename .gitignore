# =============================================================================
# Root .gitignore for the Bengali TTS platform monorepo.
# Applies recursively to tts-api-service/ and indicf5-model-server/ too.
# (Each sub-repo also has its own .gitignore for when pushed separately.)
# =============================================================================

# ---- Secrets & env (NEVER commit) ----
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/

# ---- Node / TypeScript ----
node_modules/
dist/
build/
*.tsbuildinfo
coverage/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# ---- Prisma / local databases ----
# Keep prisma/schema.prisma and prisma/migrations/ — ignore only local DBs.
# Un-anchored so they match at any depth (e.g. tts-api-service/prisma/dev.db).
*.db
*.db-journal
*.sqlite
*.sqlite3

# ---- Python (model server) ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- ML model cache & weights ----
hf_home/
.cache/
huggingface/
*.safetensors
*.ckpt
*.pt
*.pth
*.onnx
*.bin

# ---- Audio artifacts ----
# Generated/test audio and the server-side reference voice are not committed.
# (reference/README.md and reference/.gitkeep are kept — they aren't audio.)
*.mp3
*.flac
*.ogg
out.wav

# ---- Logs ----
logs/
*.log

# ---- OS / editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
