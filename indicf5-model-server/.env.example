# =============================================================================
# indicf5-model-server environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# ---- Runtime ----
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# ---- Internal auth ----
# Shared secret required on every request as `X-Internal-Token`.
# MUST equal MODEL_SERVER_INTERNAL_TOKEN in tts-api-service.
INTERNAL_TOKEN=change-me-internal-shared-secret

# ---- Model ----
MODEL_ID=ai4bharat/IndicF5
MODEL_DEVICE=cpu                 # cpu|cuda
HF_HOME=/app/hf_home             # Hugging Face cache dir (persisted via volume)

# ---- Server-side reference voice (IndicF5 voice cloning) ----
# Clients never send these; they live on the server.
REFERENCE_AUDIO_PATH=/app/reference/voice.wav
REFERENCE_TEXT=এই কণ্ঠস্বরটি রেফারেন্স হিসেবে ব্যবহৃত হচ্ছে।

# ---- Limits ----
MAX_TEXT_LENGTH=5000
REQUEST_TIMEOUT_SECONDS=120
