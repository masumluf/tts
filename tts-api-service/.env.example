# =============================================================================
# tts-api-service environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# All values are validated at startup by src/config/env.ts (fail-fast).
# =============================================================================

# ---- Runtime ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info                       # trace|debug|info|warn|error
PUBLIC_BASE_URL=http://localhost:3000  # base URL used in email download links

# ---- PostgreSQL (durable source of truth) ----
DATABASE_URL=postgresql://tts:tts@postgres:5432/tts?schema=public

# ---- Redis (execution queue only) ----
REDIS_URL=redis://redis:6379

# ---- BullMQ queue (plan.md Phase 6) ----
TTS_QUEUE_NAME=tts-generation-queue
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_TYPE=exponential       # exponential|fixed
QUEUE_BACKOFF_DELAY_MS=5000
QUEUE_JOB_TIMEOUT_MS=120000
WORKER_CONCURRENCY=1

# ---- Model server (indicf5-model-server) ----
MODEL_SERVER_URL=http://model-server:8000
MODEL_SERVER_INTERNAL_TOKEN=change-me-internal-shared-secret   # must equal INTERNAL_TOKEN on the model server
MODEL_SERVER_TIMEOUT_MS=120000
MODEL_SERVER_MAX_RETRIES=3

# ---- Audio storage (MinIO / S3-compatible) ----
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=tts-audio
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true             # required for MinIO
AUDIO_URL_EXPIRY_SECONDS=3600        # presigned download URL lifetime

# ---- Email (SMTP via Nodemailer; MailHog in dev) ----
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="TTS Service <no-reply@tts.local>"

# ---- Input limits & backpressure (plan.md Phase 13, verification.md 12) ----
MAX_TEXT_LENGTH=5000                 # chars; oversized -> 413
MAX_PENDING_JOBS_PER_USER=20         # exceeded -> 429
GLOBAL_QUEUE_MAX=1000                # queue full -> 503
RATE_LIMIT_WINDOW_MS=60000           # default window; per-user limit lives in users table

# ---- API key hashing ----
API_KEY_PEPPER=change-me-pepper      # server-side pepper mixed into api_key_hash

# ---- Redis disaster recovery (plan.md Phase 9) ----
RECOVERY_ENABLED=true
RECOVERY_INTERVAL_MS=120000          # periodic scan interval
STALE_PROCESSING_TIMEOUT_MS=180000   # processing longer than this -> re-enqueue

# ---- Incident alerting (plan.md Phase 10) ----
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=oncall@tts.local
SENTRY_DSN=
FAILURE_RATE_WINDOW_MS=300000        # window for "too many failures"
FAILURE_RATE_THRESHOLD=10            # failures within window -> alert
QUEUE_BACKLOG_THRESHOLD=500          # waiting jobs above this -> alert
STUCK_JOB_THRESHOLD_MS=300000        # job processing longer than this -> alert
