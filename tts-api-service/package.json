{
  "name": "tts-api-service",
  "version": "0.1.0",
  "private": true,
  "description": "Public TTS API service: auth, per-user job isolation, Postgres source-of-truth, BullMQ queue, worker, Redis recovery, email notifications, incident alerting. Never loads the AI model directly.",
  "type": "commonjs",
  "engines": {
    "node": ">=22 <23"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:all": "concurrently -k -n api,worker -c blue,magenta \"npm:dev\" \"npm:dev:worker\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@prisma/client": "^5.20.0",
    "axios": "^1.7.7",
    "bullmq": "^5.20.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "nodemailer": "^6.9.15",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "rate-limit-redis": "^4.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@types/nodemailer": "^6.4.16",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.0.1",
    "eslint": "^9.11.1",
    "jest": "^29.7.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0"
  }
}
