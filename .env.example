# =============================================================================
# Root docker-compose environment. Copy to `.env` before `docker compose up`.
# These values are injected into the service containers by docker-compose.yml.
# Per-repo `.env.example` files document the full variable set for each service.
# NEVER commit `.env`.
# =============================================================================

# ---- shared / cross-service ----
NODE_ENV=development
LOG_LEVEL=info
MODEL_SERVER_INTERNAL_TOKEN=change-me-internal-shared-secret
MAX_TEXT_LENGTH=5000

# ---- Postgres (managed) ----
# Point at your managed Postgres. Managed providers usually need SSL, e.g.:
#   postgresql://user:pass@host:5432/db?schema=public&sslmode=require
DATABASE_URL=postgresql://user:pass@your-managed-host:5432/tts?schema=public&sslmode=require

# ---- Redis (managed) ----
# Point at your managed Redis. Use rediss:// for TLS endpoints, e.g.:
#   rediss://default:pass@your-managed-host:6379
# Note: BullMQ needs a Redis that supports blocking commands (standard managed
# Redis / ElastiCache / Redis Cloud — NOT a REST-only serverless endpoint).
REDIS_URL=rediss://default:pass@your-managed-host:6379

# ---- Local-only Postgres/Redis containers (optional) ----
# Only used if you run:  docker compose --profile local-infra up
# Ignored when DATABASE_URL / REDIS_URL above are set.
POSTGRES_USER=tts
POSTGRES_PASSWORD=tts
POSTGRES_DB=tts
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---- MinIO (S3-compatible) ----
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=tts-audio
S3_REGION=us-east-1
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ---- MailHog ----
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
EMAIL_FROM=TTS Service <no-reply@tts.local>

# ---- API / Worker ----
API_PORT=3000
API_KEY_PEPPER=change-me-pepper
WORKER_CONCURRENCY=1
MODEL_SERVER_TIMEOUT_MS=120000
MODEL_SERVER_MAX_RETRIES=3
RECOVERY_ENABLED=true
RECOVERY_INTERVAL_MS=120000
STALE_PROCESSING_TIMEOUT_MS=180000
ALERT_SLACK_WEBHOOK_URL=
ALERT_EMAIL_TO=oncall@tts.local

# ---- Model server ----
MODEL_SERVER_PORT=8000
MODEL_ID=ai4bharat/IndicF5
MODEL_DEVICE=cpu
# ai4bharat/IndicF5 is a GATED model. 1) Accept access at
# https://huggingface.co/ai4bharat/IndicF5 while logged in, 2) create a READ
# token at https://huggingface.co/settings/tokens, 3) paste it here. Keep secret.
HF_TOKEN=hf_xxx
REFERENCE_AUDIO_PATH=/app/reference/voice.wav
REFERENCE_TEXT=এই কণ্ঠস্বরটি রেফারেন্স হিসেবে ব্যবহৃত হচ্ছে।
